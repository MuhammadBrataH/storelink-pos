{
    "version": 2,
    "framework": null,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.6.0"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "DB_CONNECTION": "mysql",
        "DB_HOST": "storelink-db-storelink-pos.l.aivencloud.com",
        "DB_PORT": "21830",
        "DB_DATABASE": "defaultdb",
        "DB_USERNAME": "avnadmin"
    }
}
